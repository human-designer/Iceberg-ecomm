<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    {%- if template == 'index' -%}{{ shop.name }} — Design-Led Engagement Rings
    {%- elsif page_title -%}{{ page_title }} — {{ shop.name }}
    {%- else -%}{{ shop.name }}{%- endif -%}
  </title>
  <meta name="description" content="{{ page_description | default: shop.description }}">
  {%- if canonical_url -%}<link rel="canonical" href="{{ canonical_url }}">{%- endif -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300;1,9..40,400&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap" rel="stylesheet">
  {{ 'tokens.css' | asset_url | stylesheet_tag }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body class="template-{{ template | replace: '/', '-' | replace: '.', '-' }}">
  {%- section 'header' -%}
  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>
  {%- section 'footer' -%}
  {%- section 'announcement-bar' -%}
  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
