{%- comment -%} Full cart line items — Sprint 3 {%- endcomment -%}
<form action="/cart" method="post" class="cart-form">
  {%- for item in cart.items -%}
    <div class="cart-item">
      <div class="cart-item__image">
        {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item.title }}
      </div>
      <div class="cart-item__details">
        <p class="cart-item__title">{{ item.product.title }}</p>
        <p class="cart-item__variant">{{ item.variant.title }}</p>
        <p class="cart-item__price">{{ item.line_price | money }}</p>
      </div>
    </div>
  {%- endfor -%}
  <div class="cart-totals">
    <p class="cart-totals__total">{{ cart.total_price | money }}</p>
    <button type="submit" name="checkout" class="cart-totals__checkout">Proceed to checkout</button>
  </div>
</form>
