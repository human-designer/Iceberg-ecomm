{%- comment -%}
  Usage: render 'product-card', product: product
{%- endcomment -%}
<a href="{{ product.url }}" class="product-card" aria-label="{{ product.title | escape }}">
  <div class="product-card__image-wrap">
    {%- if product.featured_image -%}
      {%- assign hover_image = product.images[1] -%}
      {{ product.featured_image | image_url: width: 900 | image_tag:
          loading: 'lazy',
          class: 'product-card__img product-card__img--primary',
          alt: product.featured_image.alt | escape }}
      {%- if hover_image -%}
        {{ hover_image | image_url: width: 900 | image_tag:
            loading: 'lazy',
            class: 'product-card__img product-card__img--hover',
            alt: hover_image.alt | escape }}
      {%- endif -%}
    {%- else -%}
      <div class="product-card__image-placeholder" aria-hidden="true"></div>
    {%- endif -%}
    <span class="product-card__expand" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M11 1H17V7" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/>
        <path d="M7 17H1V11" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/>
        <path d="M17 1L10.5 7.5" stroke="currentColor" stroke-width="1.2"/>
        <path d="M1 17L7.5 10.5" stroke="currentColor" stroke-width="1.2"/>
      </svg>
    </span>
  </div>
  <div class="product-card__info">
    {%- assign title_parts = product.title | split: ' — ' -%}
    <h3 class="product-card__title">{{ title_parts[0] }}</h3>
    <p class="product-card__desc">{{ product.metafields.descriptors.subtitle.value | default: product.metafields.descriptors.subtitle | default: title_parts[1] | default: product.type }}</p>
    <p class="product-card__price">
      {%- if product.price == 0 -%}
        <span class="product-card__enquiry">Make an Enquiry</span>
      {%- else -%}
        {{ product.price | money }}
      {%- endif -%}
    </p>
  </div>
</a>
