<section class="classics reveal" aria-label="{{ section.settings.heading | escape }}">
  <h2 class="classics__heading">{{ section.settings.heading }}</h2>

  <div class="classics__grid">
    {%- assign grid_collection = collections[section.settings.collection] -%}
    {%- if grid_collection == blank -%}
      {%- assign grid_collection = collections.all -%}
    {%- endif -%}
    {%- if grid_collection != blank and grid_collection.products.size > 0 -%}
      {%- for product in grid_collection.products limit: 6 -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..6) -%}
        <div class="product-card product-card--placeholder">
          <div class="product-card__image-wrap"></div>
          <div class="product-card__info">
            <p class="product-card__title">Iceberg No.{{ i }}</p>
            <p class="product-card__desc">1ct round brilliant lab diamond ring</p>
            <p class="product-card__price">Make an Enquiry</p>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Classics Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Iceberg Classics"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [{ "name": "Classics Collection" }]
}
{% endschema %}
