<section class="collection-page" aria-label="{{ collection.title | escape }}">

  {%- comment -%} ── Header bar: title + filter + sort ─────────────────── {%- endcomment -%}
  <div class="collection-bar">
    <h1 class="collection-bar__title">{{ collection.title }}</h1>

    <div class="collection-bar__filters" id="collectionFilters">
      {%- comment -%} Active filters {%- endcomment -%}
      {%- if current_tags.size > 0 -%}
        {%- for tag in current_tags -%}
          <a href="{{ collection.url }}/{{ current_tags | reject: tag | join: '+' }}" class="collection-filter__tag collection-filter__tag--active">
            {{ tag }} &times;
          </a>
        {%- endfor -%}
      {%- endif -%}

      {%- comment -%} All available tags {%- endcomment -%}
      {%- for tag in collection.all_tags -%}
        {%- unless current_tags contains tag -%}
          <a href="{{ collection.url }}/{{ tag }}" class="collection-filter__tag">{{ tag }}</a>
        {%- endunless -%}
      {%- endfor -%}
    </div>

    <div class="collection-bar__sort">
      <label class="collection-bar__sort-label" for="collectionSort">Sort by:</label>
      <select id="collectionSort" class="collection-bar__sort-select" onchange="window.location = this.value">
        {%- assign sort_options = 'manual,title-ascending,title-descending,price-ascending,price-descending,created-descending' | split: ',' -%}
        {%- assign sort_labels  = 'Featured,Name A–Z,Name Z–A,Price: Low–High,Price: High–Low,Newest' | split: ',' -%}
        {%- for option in sort_options -%}
          <option value="{{ collection.url }}?sort_by={{ option }}"
            {% if collection.sort_by == option or (collection.sort_by == blank and forloop.first) %}selected{% endif %}>
            {{ sort_labels[forloop.index0] }}
          </option>
        {%- endfor -%}
      </select>
    </div>
  </div>

  {%- comment -%} ── Product grid ──────────────────────────────────────── {%- endcomment -%}
  <div class="collection-grid">
    {%- assign editorial_slots = section.settings.editorial_slots | split: ',' -%}
    {%- assign product_index = 0 -%}

    {%- for product in collection.products -%}
      {%- assign product_index = forloop.index -%}

      {%- comment -%} Insert editorial image before slot if configured {%- endcomment -%}
      {%- for slot in editorial_slots -%}
        {%- assign slot_num = slot | strip | plus: 0 -%}
        {%- if slot_num == product_index -%}
          {%- assign editorial_image_key = 'editorial_image_' | append: forloop.index -%}
          {%- assign editorial_image = section.settings[editorial_image_key] -%}
          {%- if editorial_image != blank -%}
            <div class="collection-grid__editorial">
              {{ editorial_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: collection.title }}
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      {%- render 'product-card', product: product -%}
    {%- else -%}
      <p class="collection-empty">No products found.</p>
    {%- endfor -%}
  </div>

  {%- comment -%} ── Pagination ────────────────────────────────────────── {%- endcomment -%}
  {%- if paginate.pages > 1 -%}
    <div class="collection-pagination">
      {{- paginate | default_pagination -}}
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Collection Products",
  "settings": [
    {
      "type": "text",
      "id": "editorial_slots",
      "label": "Editorial image positions (comma-separated product indexes, e.g. 5,14)"
    },
    { "type": "image_picker", "id": "editorial_image_1", "label": "Editorial image 1" },
    { "type": "image_picker", "id": "editorial_image_2", "label": "Editorial image 2" },
    { "type": "image_picker", "id": "editorial_image_3", "label": "Editorial image 3" }
  ],
  "presets": [{ "name": "Collection Products" }]
}
{% endschema %}
