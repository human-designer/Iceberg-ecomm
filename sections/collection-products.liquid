{%- assign per_page = section.settings.products_per_page | default: 12 -%}
{%- paginate collection.products by per_page -%}

<section class="collection-page" aria-label="{{ collection.title | escape }}">

  {%- comment -%} ── Filter bar ──────────────────────────────────────────── {%- endcomment -%}
  <div class="collection-bar">

    <div class="collection-bar__view">
      <span class="collection-bar__view-label">View:</span>
      <button class="collection-bar__view-btn collection-bar__view-btn--active js-view-btn" data-cols="4">Four</button>
      <button class="collection-bar__view-btn js-view-btn" data-cols="2">Two</button>
    </div>

    <h1 class="collection-bar__title">{{ collection.title }}</h1>

    <div class="collection-bar__actions">
      <button class="collection-bar__filter-btn js-open-filters">Filter &amp; Sort</button>
    </div>

  </div>

  {%- comment -%} ── Product grid ──────────────────────────────────────── {%- endcomment -%}
  {%- assign editorial_pos = section.settings.editorial_position | default: 4 | plus: 0 -%}
  <div class="collection-grid js-collection-grid" data-cols="4">

    {%- for product in collection.products -%}

      {%- comment -%} Insert editorial image after product N {%- endcomment -%}
      {%- if forloop.index == editorial_pos and section.settings.editorial_image != blank -%}
        <div class="collection-grid__editorial">
          {{ section.settings.editorial_image | image_url: width: 900 | image_tag:
              loading: 'lazy',
              alt: collection.title }}
        </div>
      {%- endif -%}

      {%- render 'product-card', product: product -%}

    {%- else -%}
      <p class="collection-empty">No products found.</p>
    {%- endfor -%}

  </div>

  {%- comment -%} ── Load more / pagination ────────────────────────────── {%- endcomment -%}
  {%- if paginate.pages > 1 -%}
    {%- assign progress_pct = paginate.current_page | times: 100 | divided_by: paginate.pages -%}
    <div class="collection-load-more">
      <div class="collection-load-more__tracker">
        <div class="collection-load-more__progress" style="width: {{ progress_pct }}%"></div>
      </div>
      {%- if paginate.next -%}
        {%- assign remaining = collection.products_count | minus: paginate.current_offset | minus: per_page -%}
        <a href="{{ paginate.next.url }}" class="collection-load-more__btn">
          Load {{ remaining }} more products
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── SEO text + breadcrumbs ────────────────────────────── {%- endcomment -%}
  {%- if collection.description != blank or section.settings.seo_text != blank -%}
    <div class="collection-seo">
      <div class="collection-seo__text rte">
        {%- if section.settings.seo_text != blank -%}
          {{ section.settings.seo_text }}
        {%- else -%}
          {{ collection.description }}
        {%- endif -%}
      </div>
      <nav class="collection-seo__breadcrumbs" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">All Jewellery</a>
        <span>/</span>
        <a href="{{ routes.collections_url }}">Collections</a>
        <span>/</span>
        <span>{{ collection.title }}</span>
      </nav>
    </div>
  {%- endif -%}

</section>

<script>
  (function() {
    var grid = document.querySelector('.js-collection-grid');
    var btns = document.querySelectorAll('.js-view-btn');
    btns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var cols = this.dataset.cols;
        grid.dataset.cols = cols;
        btns.forEach(function(b) { b.classList.remove('collection-bar__view-btn--active'); });
        this.classList.add('collection-bar__view-btn--active');
      });
    });
  })();
</script>

{%- endpaginate -%}

{% schema %}
{
  "name": "Collection Products",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 12
    },
    {
      "type": "image_picker",
      "id": "editorial_image",
      "label": "Editorial image"
    },
    {
      "type": "number",
      "id": "editorial_position",
      "label": "Insert editorial image after product #",
      "default": 4
    },
    {
      "type": "richtext",
      "id": "seo_text",
      "label": "SEO description (overrides collection description)"
    }
  ],
  "presets": [{ "name": "Collection Products" }]
}
{% endschema %}
