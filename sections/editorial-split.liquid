<section class="editorial-split editorial-split--{{ section.settings.layout }}{% if section.settings.style == 'aside' %} editorial-split--aside{% endif %} reveal">
  <div class="editorial-split__image{% if section.settings.image_small != blank %} editorial-split__image--has-accent{% endif %}">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1400 | image_tag:
          loading: 'lazy',
          alt: section.settings.image_alt | escape }}
    {%- else -%}
      <div class="editorial-split__image-placeholder" aria-hidden="true"></div>
    {%- endif -%}
    {%- if section.settings.image_small != blank -%}
      <div class="editorial-split__image-accent">
        {{ section.settings.image_small | image_url: width: 400 | image_tag:
            loading: 'lazy',
            alt: section.settings.image_alt | escape }}
      </div>
    {%- endif -%}
  </div>
  <div class="editorial-split__content">
    {%- if section.settings.label != blank -%}
      <p class="section-label">{{ section.settings.label }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="editorial-split__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="editorial-split__body rte">{{ section.settings.body }}</div>
    {%- endif -%}
    {%- if section.settings.link_text != blank -%}
      <a href="{{ section.settings.link_url | default: '#' }}" class="btn-outline">
        {{ section.settings.link_text }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Editorial Split",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        { "value": "image_left",  "label": "Image left" },
        { "value": "image_right", "label": "Image right" }
      ],
      "default": "image_left"
    },
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "options": [
        { "value": "default", "label": "Default (50/50)" },
        { "value": "aside",   "label": "Aside (landscape image)" }
      ],
      "default": "default"
    },
    { "type": "image_picker", "id": "image",       "label": "Image (large)" },
    { "type": "image_picker", "id": "image_small", "label": "Image (small accent, bottom-left)" },
    { "type": "text",         "id": "image_alt",   "label": "Image alt text" },
    { "type": "text",         "id": "label",      "label": "Small label" },
    { "type": "text",         "id": "title",      "label": "Title" },
    { "type": "richtext",     "id": "body",       "label": "Body copy" },
    { "type": "text",         "id": "link_text",  "label": "Button text" },
    { "type": "url",          "id": "link_url",   "label": "Button URL" }
  ],
  "presets": [{ "name": "Editorial Split" }]
}
{% endschema %}
