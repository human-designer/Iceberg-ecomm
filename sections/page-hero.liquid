<section class="page-hero">
  {%- if section.settings.label != blank -%}
    <p class="section-label">{{ section.settings.label }}</p>
  {%- endif -%}
  <h1 class="page-hero__title">{{ section.settings.title | default: page.title }}</h1>
</section>

{% schema %}
{
  "name": "Page Hero",
  "settings": [
    { "type": "text", "id": "label", "label": "Section label" },
    { "type": "text", "id": "title", "label": "Override page title (leave blank to use page title)" }
  ],
  "presets": [{ "name": "Page Hero" }]
}
{% endschema %}
