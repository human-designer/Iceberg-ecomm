{%- comment -%}
  Section: product-main
  Displays the primary product purchase area — image gallery + info panel.
{%- endcomment -%}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign has_images = false -%}
{%- if product.images.size > 0 -%}{%- assign has_images = true -%}{%- endif -%}

<script>
  window.__pdpVariants = {{ product.variants | json }};
</script>

<section class="pdp" data-section-id="{{ section.id }}" data-section-type="product-main">
  <div class="pdp__layout">

    {%- comment -%} ── Gallery ──────────────────────────────────────── {%- endcomment -%}
    <div class="pdp__gallery">

      {%- comment -%} Mobile: swipe carousel {%- endcomment -%}
      <div class="pdp__carousel" id="pdpCarousel" data-carousel>
        <div class="pdp__carousel-track" id="pdpTrack">
          {%- if has_images -%}
            {%- for image in product.images -%}
              <div class="pdp__carousel-slide">
                {{ image | image_url: width: 800 | image_tag:
                    alt: image.alt | default: product.title,
                    loading: 'eager',
                    widths: '400, 600, 800' }}
              </div>
            {%- endfor -%}
          {%- else -%}
            <div class="pdp__carousel-slide pdp__carousel-slide--placeholder"></div>
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="pdp__carousel-dots" role="tablist" aria-label="Product images">
            {%- for image in product.images -%}
              <button class="pdp__carousel-dot{% if forloop.first %} is-active{% endif %}"
                      role="tab"
                      data-slide="{{ forloop.index0 }}"
                      aria-label="Image {{ forloop.index }}"
                      aria-selected="{{ forloop.first }}"></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Desktop: hero + thumbnail grid {%- endcomment -%}
      <div class="pdp__gallery-desktop">
        <div class="pdp__gallery-hero">
          {%- if product.featured_image -%}
            {{ product.featured_image | image_url: width: 1400 | image_tag:
                alt: product.featured_image.alt | default: product.title,
                loading: 'eager',
                widths: '700, 1000, 1400',
                class: 'pdp__gallery-img' }}
          {%- else -%}
            <div class="pdp__gallery-placeholder"></div>
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="pdp__gallery-thumbs">
            {%- for image in product.images offset: 1 limit: 4 -%}
              <button class="pdp__gallery-thumb" data-thumb="{{ forloop.index0 | plus: 1 }}" aria-label="View image {{ forloop.index | plus: 1 }}">
                {{ image | image_url: width: 600 | image_tag:
                    alt: image.alt | default: product.title,
                    loading: 'lazy',
                    widths: '300, 450, 600' }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

    </div>

    {%- comment -%} ── Info Panel ──────────────────────────────────── {%- endcomment -%}
    <div class="pdp__info">

      <div class="pdp__purchase">

      {%- comment -%} Category + Title + Description {%- endcomment -%}
      <div class="pdp__header">
        <div class="pdp__header-top">
          {%- if product.type != blank -%}
            <p class="pdp__category">{{ product.type }}</p>
          {%- elsif product.collections.first != blank -%}
            <p class="pdp__category">{{ product.collections.first.title }}</p>
          {%- endif -%}
          <h1 class="pdp__title">{{ product.title }}</h1>
        </div>

        {%- if product.description != blank -%}
          <div class="pdp__desc">
            <div class="pdp__desc-text">
              {{- product.description | strip_html -}}
            </div>
            <button class="pdp__read-more" data-expand-desc aria-expanded="false">Read more</button>
          </div>
        {%- endif -%}

        {%- comment -%} Specs grid {%- endcomment -%}
        {%- assign m_material = product.metafields.custom.material.value -%}
        {%- assign m_shape    = product.metafields.custom.shape.value -%}
        {%- assign m_cut      = product.metafields.custom.cut.value -%}
        {%- assign m_carat    = product.metafields.custom.carat.value -%}
        {%- assign m_clarity  = product.metafields.custom.clarity.value -%}
        {%- assign m_colour   = product.metafields.custom.colour.value -%}

        {%- if m_material or m_shape or m_cut or m_carat or m_clarity or m_colour -%}
          <div class="pdp__specs-wrap">
            <div class="pdp__specs-grid">
              <div class="pdp__spec">
                <span class="pdp__spec-label">Material</span>
                <span class="pdp__spec-value">{{ m_material | default: '—' }}</span>
              </div>
              <div class="pdp__spec">
                <span class="pdp__spec-label">Shape</span>
                <span class="pdp__spec-value">{{ m_shape | default: '—' }}</span>
              </div>
              <div class="pdp__spec">
                <span class="pdp__spec-label">Cut</span>
                <span class="pdp__spec-value">{{ m_cut | default: '—' }}</span>
              </div>
              <div class="pdp__spec">
                <span class="pdp__spec-label">Carat</span>
                <span class="pdp__spec-value">{{ m_carat | default: '—' }}</span>
              </div>
              <div class="pdp__spec">
                <span class="pdp__spec-label">Clarity</span>
                <span class="pdp__spec-value">{{ m_clarity | default: '—' }}</span>
              </div>
              <div class="pdp__spec">
                <span class="pdp__spec-label">Colour</span>
                <span class="pdp__spec-value">{{ m_colour | default: '—' }}</span>
              </div>
            </div>
            {%- assign carat_sizes = product.metafields.custom.carat_sizes.value -%}
            {%- if carat_sizes != blank -%}
              <button class="pdp__specs-cta">+ {{ carat_sizes }} carat sizes</button>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Purchase form {%- endcomment -%}
      {%- form 'product', product, id: 'pdp-form', class: 'pdp__form', novalidate: true -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}" id="pdpVariantId">

        {%- comment -%} Ring Size trigger {%- endcomment -%}
        {%- for option in product.options_with_values -%}
          {%- assign opt_lower = option.name | downcase -%}
          {%- if opt_lower contains 'size' -%}
            <button type="button" class="pdp__size-trigger" id="pdpSizeTrigger" aria-expanded="false" aria-controls="pdpSizeRail">
              <span class="pdp__size-label">
                Ring Size
                <span class="pdp__size-selected" id="pdpSizeSelected">
                  {%- if option.selected_value != blank -%}— {{ option.selected_value }}{%- endif -%}
                </span>
              </span>
              <span class="pdp__size-icon">{%- render 'icon-chevron' -%}</span>
            </button>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Price {%- endcomment -%}
        <div class="pdp__price-row">
          <span class="pdp__price" id="pdpPrice">
            {%- if current_variant.price == 0 -%}
              Price on Application
            {%- else -%}
              {{ current_variant.price | money }}
            {%- endif -%}
          </span>
        </div>

        {%- comment -%} CTA buttons {%- endcomment -%}
        <div class="pdp__actions">
          {%- if current_variant.available -%}
            <button type="submit" name="add" class="pdp__btn-add">Add to Cart</button>
          {%- else -%}
            <button type="button" class="pdp__btn-add pdp__btn-add--sold-out" disabled>Sold Out</button>
          {%- endif -%}
          <a href="{{ section.settings.enquiry_url | default: '/pages/contact' }}" class="pdp__btn-enquiry">
            Make an Enquiry
          </a>
        </div>

        {%- comment -%} Made to order note {%- endcomment -%}
        {%- if section.settings.made_to_order_note != blank -%}
          <p class="pdp__made-to-order">
            <strong>Made To Order:</strong> {{ section.settings.made_to_order_note }}
          </p>
        {%- endif -%}

      {%- endform -%}

      </div>{%- comment -%} /.pdp__purchase {%- endcomment -%}

      {%- comment -%} Info accordions {%- endcomment -%}
      <div class="pdp__accordion">

        {%- for block in section.blocks -%}
          {%- if block.type == 'accordion' -%}
            <details class="pdp__accordion-item" {{ block.shopify_attributes }}>
              <summary class="pdp__accordion-trigger">
                <span class="pdp__accordion-label">{{ block.settings.heading }}</span>
                <span class="pdp__accordion-icon">{%- render 'icon-chevron' -%}</span>
              </summary>
              {%- if block.settings.content != blank -%}
                <div class="pdp__accordion-content rte">{{ block.settings.content }}</div>
              {%- endif -%}
            </details>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Fallback default accordions if no blocks set {%- endcomment -%}
        {%- if section.blocks.size == 0 -%}
          <details class="pdp__accordion-item">
            <summary class="pdp__accordion-trigger">
              <span class="pdp__accordion-label">Diamond Standard</span>
              <span class="pdp__accordion-icon">{%- render 'icon-chevron' -%}</span>
            </summary>
            <div class="pdp__accordion-content rte">
              <p>Every diamond we use meets our exacting standards for cut, clarity, and colour — sourced with full traceability and certified to the highest grades.</p>
            </div>
          </details>
          <details class="pdp__accordion-item">
            <summary class="pdp__accordion-trigger">
              <span class="pdp__accordion-label">Premium Complimentary Shipping &amp; Returns</span>
              <span class="pdp__accordion-icon">{%- render 'icon-chevron' -%}</span>
            </summary>
            <div class="pdp__accordion-content rte">
              <p>Complimentary insured shipping on all orders. Free returns within 30 days of delivery.</p>
            </div>
          </details>
          <details class="pdp__accordion-item">
            <summary class="pdp__accordion-trigger">
              <span class="pdp__accordion-label">Iceberg Exceptional Craftsmanship</span>
              <span class="pdp__accordion-icon">{%- render 'icon-chevron' -%}</span>
            </summary>
            <div class="pdp__accordion-content rte">
              <p>Every piece is handcrafted in our atelier to the highest standards of precision and finish.</p>
            </div>
          </details>
          <details class="pdp__accordion-item">
            <summary class="pdp__accordion-trigger">
              <span class="pdp__accordion-label">Contact Us</span>
              <span class="pdp__accordion-icon">{%- render 'icon-chevron' -%}</span>
            </summary>
            <div class="pdp__accordion-content rte">
              <p>Have questions about this piece? <a href="/pages/contact">Get in touch</a> with our team — we're happy to help.</p>
            </div>
          </details>
        {%- endif -%}

      </div>

    </div>
  </div>

  {%- comment -%} ── Right-rail size drawer ──────────────────────────────── {%- endcomment -%}
  <div class="size-rail" id="pdpSizeRail" aria-hidden="true" aria-label="Choose ring size">
    <div class="size-rail__overlay" id="pdpSizeOverlay"></div>
    <div class="size-rail__panel">

      <div class="size-rail__top">

        {%- comment -%} Header: tabs + close {%- endcomment -%}
        <div class="size-rail__header">
          <div class="size-rail__tabs" role="tablist">
            <button class="size-rail__tab is-active" role="tab" data-tab="eu" aria-selected="true">EU Sizes</button>
            <button class="size-rail__tab" role="tab" data-tab="us" aria-selected="false">US Sizes</button>
          </div>
          <button class="size-rail__close" id="pdpSizeClose" aria-label="Close">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="4" y1="4" x2="16" y2="16" stroke="#141414" stroke-width="1.5"/>
              <line x1="16" y1="4" x2="4" y2="16" stroke="#141414" stroke-width="1.5"/>
            </svg>
          </button>
        </div>

        {%- comment -%} Size list — data-eu holds the Shopify option value; JS fills data-us {%- endcomment -%}
        {%- for option in product.options_with_values -%}
          {%- assign opt_lower = option.name | downcase -%}
          {%- if opt_lower contains 'size' -%}
            <div class="size-rail__list" id="pdpSizeList">
              {%- for value in option.values -%}
                <button type="button"
                        class="size-rail__item{% if option.selected_value == value %} is-selected{% endif %}"
                        data-eu="{{ value | escape }}"
                        data-option-index="{{ forloop.parentloop.index0 }}">
                  <span class="size-rail__item-label">{{ value }}</span>
                  {%- if option.selected_value == value -%}
                    <span class="size-rail__item-badge">Selected</span>
                  {%- endif -%}
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endfor -%}

        <p class="size-rail__another">Request another size</p>

      </div>

      <div class="size-rail__footer">
        <div class="size-rail__assistance">
          <p class="size-rail__assistance-heading">Need assistance choosing your size?</p>
          <p class="size-rail__assistance-body">If you are uncertain of your size, we recommend visiting a local jeweller for a professional fitting, or contact us at <a href="mailto:{{ section.settings.enquiry_email | default: 'info@iceberg.com' }}">{{ section.settings.enquiry_email | default: 'info@iceberg.com' }}</a></p>
        </div>
        <button type="button" class="size-rail__add pdp__btn-add" id="pdpSizeAdd">Add to Cart</button>
      </div>

    </div>
  </div>

</section>

{% schema %}
{
  "name": "Product Main",
  "settings": [
    {
      "type": "text",
      "id": "made_to_order_note",
      "label": "Made to Order note",
      "default": "This custom piece takes 8–10 weeks to produce before shipping."
    },
    {
      "type": "url",
      "id": "enquiry_url",
      "label": "Enquiry page URL"
    },
    {
      "type": "text",
      "id": "enquiry_email",
      "label": "Enquiry email address",
      "default": "info@iceberg.com"
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Details"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Main",
      "blocks": [
        { "type": "accordion", "settings": { "heading": "Diamond Standard" } },
        { "type": "accordion", "settings": { "heading": "Premium Complimentary Shipping & Returns" } },
        { "type": "accordion", "settings": { "heading": "Iceberg Exceptional Craftsmanship" } },
        { "type": "accordion", "settings": { "heading": "Contact Us" } }
      ]
    }
  ]
}
{% endschema %}
