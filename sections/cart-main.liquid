<section class="cart-page">
  <div class="cart-page__inner">

    <h1 class="cart-page__title">Your Cart</h1>

    {%- if cart.item_count == 0 -%}
      <p class="cart-page__empty">Your cart is empty. <a href="/collections/all">Explore the collection.</a></p>
    {%- else -%}

      <form action="/cart" method="post" class="cart-form">

        {%- comment -%} Column headers {%- endcomment -%}
        <div class="cart-header">
          <span class="cart-header__col cart-header__col--product">Product</span>
          <span class="cart-header__col cart-header__col--qty">Quantity</span>
          <span class="cart-header__col cart-header__col--total">Total</span>
        </div>

        {%- comment -%} Line items {%- endcomment -%}
        <div class="cart-items">
          {%- for item in cart.items -%}
            <div class="cart-item">

              <div class="cart-item__product">
                <a href="{{ item.url }}" class="cart-item__image-link">
                  {{- item.image | image_url: width: 160 | image_tag:
                      loading: 'lazy',
                      alt: item.title,
                      class: 'cart-item__img' -}}
                </a>
                <div class="cart-item__meta">
                  <p class="cart-item__title">{{ item.product.title }}</p>
                  {%- unless item.variant.title == 'Default Title' -%}
                    <p class="cart-item__variant">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  <p class="cart-item__price">{{ item.original_line_price | money }}</p>
                  <a href="/cart/change?line={{ forloop.index }}&quantity=0"
                     class="cart-item__remove"
                     aria-label="Remove {{ item.title | escape }}">Remove</a>
                </div>
              </div>

              <div class="cart-item__qty">
                {{ item.quantity }}
              </div>

              <div class="cart-item__total">
                {{ item.line_price | money }}
              </div>

            </div>
          {%- endfor -%}
        </div>

        {%- comment -%} Totals + checkout {%- endcomment -%}
        <div class="cart-summary">
          <div class="cart-summary__row">
            <span class="cart-summary__label">Estimated total</span>
            <span class="cart-summary__value">{{ cart.total_price | money_with_currency }}</span>
          </div>
          <p class="cart-summary__note">Taxes included. Discounts and <a href="/policies/shipping-policy">shipping</a> calculated at checkout.</p>
          <button type="submit" name="checkout" class="cart-summary__checkout">Checkout</button>
        </div>

      </form>

    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Cart", "settings": [] }
{% endschema %}
