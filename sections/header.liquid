<nav class="nav" id="nav" role="navigation" aria-label="Main navigation">
  <ul class="nav__links">
    {%- for link in linklists['main-menu'].links -%}
      <li><a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a></li>
    {%- endfor -%}
  </ul>

  <a href="/" class="nav__brand" aria-label="{{ shop.name }} home">
    {%- if shop.brand.logo -%}
      {{ shop.brand.logo | image_url: width: 400 | image_tag:
          class: 'nav__brand-logo',
          alt: shop.name,
          loading: 'eager' }}
    {%- else -%}
      {{ shop.name }}
    {%- endif -%}
  </a>

  <div class="nav__actions">
    {%- for link in linklists['secondary-menu'].links -%}
      <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
    {%- endfor -%}
    {%- if shop.customer_accounts_enabled -%}
      <a href="/account" aria-label="Account">Account</a>
    {%- endif -%}
    <a href="/cart" class="nav__cart" aria-label="Cart ({{ cart.item_count }} items)">
      {%- render 'icon-cart' -%}
      {%- if cart.item_count > 0 -%}
        <span class="nav__cart-count">{{ cart.item_count }}</span>
      {%- endif -%}
    </a>
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
