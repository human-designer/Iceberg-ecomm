<div class="footer-sticky-wrap">
<div class="footer-sticky-inner">
<footer class="footer" role="contentinfo">

  {%- comment -%} ── Logo band ─────────────────────────────────────────── {%- endcomment -%}
  <div class="footer__logo-band">
    {% render 'icon-wordmark' %}
  </div>

  {%- comment -%} ── Main row ──────────────────────────────────────────── {%- endcomment -%}
  <div class="footer__main">

    {%- comment -%} Left: email signup + social + copyright {%- endcomment -%}
    <div class="footer__left footer-reveal" style="--i:0">

      <div class="footer__signup">
        <p class="footer__signup-heading">Be the first to see what's coming. Join our email list.</p>
        <form class="footer__email-form" action="/contact#footer-signup" method="post" accept-charset="UTF-8">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer__email-row">
            <input
              class="footer__email-input"
              type="email"
              name="contact[email]"
              placeholder="Your email"
              autocomplete="email"
              required
            >
            <button class="footer__email-btn" type="submit" aria-label="Subscribe">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="#21344A" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </form>
      </div>

      <div class="footer__social-block">
        <div class="footer__social-icons">
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="2" width="20" height="20" rx="5" stroke="#21344A" stroke-width="2"/>
                <circle cx="12" cy="12" r="4" stroke="#21344A" stroke-width="2"/>
                <circle cx="17.5" cy="6.5" r="1" fill="#21344A"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook_url != blank -%}
            <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#21344A" xmlns="http://www.w3.org/2000/svg">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#21344A" xmlns="http://www.w3.org/2000/svg">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.pinterest_url != blank -%}
            <a href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener" aria-label="Pinterest">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#21344A" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.77 1.22-5.17 1.22-5.17s-.31-.63-.31-1.56c0-1.46.85-2.55 1.9-2.55.9 0 1.33.67 1.33 1.48 0 .9-.58 2.26-.87 3.51-.25 1.05.52 1.9 1.54 1.9 1.85 0 3.09-2.37 3.09-5.17 0-2.14-1.44-3.64-3.5-3.64-2.38 0-3.78 1.79-3.78 3.63 0 .72.28 1.49.62 1.91.07.08.08.15.06.23-.06.26-.2.84-.23.95-.04.15-.13.18-.3.11-1.12-.52-1.82-2.17-1.82-3.49 0-2.84 2.06-5.44 5.94-5.44 3.12 0 5.54 2.22 5.54 5.19 0 3.1-1.95 5.59-4.65 5.59-.91 0-1.76-.47-2.05-1.03l-.56 2.08c-.2.78-.75 1.76-1.12 2.35.85.26 1.75.4 2.68.4 5.52 0 10-4.48 10-10S17.52 2 12 2z"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
        <p class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</p>
      </div>

    </div>

    {%- comment -%} Right: nav columns {%- endcomment -%}
    <div class="footer__nav">

      <div class="footer__nav-col footer-reveal" style="--i:1">
        <p class="footer__nav-heading">Resources</p>
        <ul class="footer__nav-links">
          <li style="--i:0"><a href="#">Showroom Walk In Hours</a></li>
          <li style="--i:1"><a href="/pages/about">About</a></li>
          <li style="--i:2"><a href="/products/gift-card">Gift Card</a></li>
          <li style="--i:3"><a href="#">Careers</a></li>
          <li style="--i:4"><a href="#">Guidance</a></li>
          <li style="--i:5"><a href="#">How to Care for Your Jewelry</a></li>
          <li style="--i:6"><a href="#">Ethical Sourcing</a></li>
          <li style="--i:7"><a href="#">Reset Your Diamond</a></li>
        </ul>
      </div>

      <div class="footer__nav-col footer-reveal" style="--i:2">
        <p class="footer__nav-heading">Policies</p>
        <ul class="footer__nav-links">
          <li style="--i:0"><a href="#">FAQs</a></li>
          <li style="--i:1"><a href="/policies/refund-policy">Warranty &amp; Repairs</a></li>
          <li style="--i:2"><a href="#">Ring Sizing &amp; Resizing</a></li>
          <li style="--i:3"><a href="/policies/refund-policy">Returns, Exchanges &amp; Cancellations</a></li>
          <li style="--i:4"><a href="#">Payment &amp; Financing</a></li>
          <li style="--i:5"><a href="/policies/shipping-policy">Shipping &amp; Packaging</a></li>
        </ul>
      </div>

      <div class="footer__nav-col footer-reveal" style="--i:3">
        <p class="footer__nav-heading">Customer Care</p>
        <p class="footer__care-body">No matter how you contact us, you'll speak with a real human who wants to help.</p>
        <div class="footer__care-divider"></div>
        <p class="footer__care-label">Email Us</p>
        <p class="footer__care-detail footer__care-detail--bold"><a href="mailto:{{ section.settings.email }}">Send a note and we will reply in a day.</a></p>
        <div class="footer__care-divider"></div>
        <p class="footer__care-label">Call Us</p>
        <p class="footer__care-detail">Give us a ring or shoot us a text: {{ section.settings.phone }}</p>
      </div>

    </div>
  </div>

</footer>
</div>
</div>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "url",  "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url",  "id": "facebook_url",  "label": "Facebook URL" },
    { "type": "url",  "id": "tiktok_url",    "label": "TikTok URL" },
    { "type": "url",  "id": "pinterest_url", "label": "Pinterest URL" },
    { "type": "text", "id": "email",         "label": "Contact email",  "default": "hello@icebergjewelry.com" },
    { "type": "text", "id": "phone",         "label": "Phone number",   "default": "(781) 205-9868" }
  ]
}
{% endschema %}
