<section class="hero" aria-label="Hero">
  {%- if section.settings.video != blank -%}
    <video class="hero__media" autoplay muted loop playsinline
           aria-hidden="true"
           poster="{{ section.settings.video_poster | image_url: width: 2000 }}">
      <source src="{{ section.settings.video }}" type="video/mp4">
    </video>
  {%- elsif section.settings.image != blank -%}
    <div class="hero__media">
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', fetchpriority: 'high', alt: '' }}
    </div>
  {%- else -%}
    <div class="hero__media hero__media--placeholder" aria-hidden="true"></div>
  {%- endif -%}
</section>

