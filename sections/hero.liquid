<section class="hero" aria-label="Hero">
  {%- if section.settings.image != blank -%}
    <div class="hero__media">
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', fetchpriority: 'high', alt: '' }}
    </div>
  {%- else -%}
    <div class="hero__media hero__media--placeholder" aria-hidden="true"></div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
