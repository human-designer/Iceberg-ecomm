{%- comment -%}
  Diamonds landing page — hero, explore collections, image-with-text blocks, quote, product grid
{%- endcomment -%}

<section class="diamonds" aria-label="Diamonds">

  {%- comment -%} ── Hero image ─────────────────────────────────────────── {%- endcomment -%}
  <div class="diamonds__hero">
    {%- if section.settings.hero_image != blank -%}
      {{ section.settings.hero_image | image_url: width: 1800 | image_tag:
          loading: 'eager',
          class: 'diamonds__hero-img',
          alt: section.settings.hero_heading | default: 'Diamonds' }}
    {%- else -%}
      <div class="diamonds__hero-placeholder"></div>
    {%- endif -%}
  </div>

  {%- comment -%} ── Explore Collections ───────────────────────────────── {%- endcomment -%}
  <div class="diamonds__explore">
    <h2 class="diamonds__explore-heading">{{ section.settings.explore_heading | default: 'Explore Collections' }}</h2>
    <div class="diamonds__explore-body rte">
      {{ section.settings.explore_text }}
    </div>
    <div class="diamonds__explore-links">
      {%- for block in section.blocks -%}
        {%- if block.type == 'collection_link' -%}
          <a href="{{ block.settings.link }}" class="diamonds__explore-link" {{ block.shopify_attributes }}>
            {{ block.settings.label }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} ── Image with text blocks ────────────────────────────── {%- endcomment -%}
  {%- assign iwt_index = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'image_with_text' -%}
      {%- assign iwt_index = iwt_index | plus: 1 -%}
      {%- assign is_reversed = iwt_index | modulo: 2 -%}
      <div class="diamonds__iwt{% if is_reversed == 0 %} diamonds__iwt--reversed{% endif %}" {{ block.shopify_attributes }}>
        <div class="diamonds__iwt-media">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag:
                loading: 'lazy',
                class: 'diamonds__iwt-img',
                alt: block.settings.heading | escape }}
          {%- else -%}
            <div class="diamonds__iwt-placeholder"></div>
          {%- endif -%}
        </div>
        <div class="diamonds__iwt-content">
          <h3 class="diamonds__iwt-heading">{{ block.settings.heading }}</h3>
          <div class="diamonds__iwt-text">{{ block.settings.text }}</div>
          {%- if block.settings.link_label != blank -%}
            <a href="{{ block.settings.link_url }}" class="diamonds__iwt-link">{{ block.settings.link_label }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} ── Quote ─────────────────────────────────────────────── {%- endcomment -%}
  {%- if section.settings.quote_text != blank -%}
    <div class="diamonds__quote">
      <blockquote class="diamonds__quote-text">{{ section.settings.quote_text }}</blockquote>
      {%- if section.settings.quote_attribution != blank -%}
        <cite class="diamonds__quote-cite">{{ section.settings.quote_attribution }}</cite>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Product grid ──────────────────────────────────────── {%- endcomment -%}
  {%- if section.settings.collection != blank -%}
    {%- assign diamond_collection = collections[section.settings.collection] -%}
    {%- assign product_limit = section.settings.product_count | default: 8 -%}
    <div class="diamonds__products">
      {%- for product in diamond_collection.products limit: product_limit -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Diamonds Page",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Explore Collections"
    },
    {
      "type": "text",
      "id": "explore_heading",
      "label": "Heading",
      "default": "EXPLORE COLLECTIONS"
    },
    {
      "type": "richtext",
      "id": "explore_text",
      "label": "Body text"
    },
    {
      "type": "header",
      "content": "Quote"
    },
    {
      "type": "text",
      "id": "quote_text",
      "label": "Quote text",
      "default": "\"I wanted to create timeless bridal rings with the center stone at the heart. I kept asking myself how classic they could be – yet still carry my expression, that sense of diamonds dancing above the hand.\""
    },
    {
      "type": "text",
      "id": "quote_attribution",
      "label": "Attribution",
      "default": "– Sophie van den Berg"
    },
    {
      "type": "header",
      "content": "Product Grid"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of products",
      "min": 4,
      "max": 16,
      "step": 4,
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "collection_link",
      "name": "Collection Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "image_with_text",
      "name": "Image with Text",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Collection Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Body text"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Discover"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Diamonds Page",
      "blocks": [
        { "type": "collection_link", "settings": { "label": "Engagement" }},
        { "type": "collection_link", "settings": { "label": "Wedding Bands" }},
        { "type": "collection_link", "settings": { "label": "Wedding Sets" }},
        { "type": "collection_link", "settings": { "label": "Men's Rings" }},
        { "type": "image_with_text", "settings": { "heading": "Collection #1", "link_label": "Discover" }},
        { "type": "image_with_text", "settings": { "heading": "Wedding Bands", "link_label": "Discover" }},
        { "type": "image_with_text", "settings": { "heading": "Book a Bridal Appointment", "link_label": "Book An Appointment" }}
      ]
    }
  ]
}
{% endschema %}
